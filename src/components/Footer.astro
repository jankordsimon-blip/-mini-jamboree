---
import { event } from "../config/event";

// 👉 neu: Base-Pfad
const base = import.meta.env.BASE_URL;
---

<footer class="mt-16 border-t border-slate-200 bg-white/70 backdrop-blur dark:border-slate-800 dark:bg-slate-950/40">
  <div class="mx-auto max-w-6xl px-6 py-12 text-sm text-slate-600 dark:text-slate-300">
    <div class="flex flex-col gap-6 md:flex-row md:items-start md:justify-between">
      
      <div>
        <p class="font-semibold text-slate-900 dark:text-white">{event.name}</p>
        <p class="mt-2">{event.date} · {event.location}</p>
        <p class="mt-4">
          Contact:{" "}
          <a class="underline hover:text-slate-900 dark:hover:text-white" href={"mailto:" + event.contactEmail}>
            {event.contactEmail}
          </a>
        </p>
      </div>

      <div class="w-full md:w-[420px]">
        <div class="flex items-center justify-between gap-4">
          <p class="font-semibold text-slate-900 dark:text-white">Sponsors</p>

          <!-- ✅ FIXED LINK -->
          <a
            class="text-xs underline hover:text-slate-900 dark:hover:text-white"
            href={`${base}/contact`}
          >
            Become a sponsor
          </a>
        </div>

        <div class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-4">
          <div class="rounded-xl border border-slate-200 bg-white px-3 py-3 text-center text-xs text-slate-500 shadow-sm dark:border-slate-800 dark:bg-slate-950 dark:text-slate-400">
            Logo 1
          </div>
          <div class="rounded-xl border border-slate-200 bg-white px-3 py-3 text-center text-xs text-slate-500 shadow-sm dark:border-slate-800 dark:bg-slate-950 dark:text-slate-400">
            Logo 2
          </div>
          <div class="rounded-xl border border-slate-200 bg-white px-3 py-3 text-center text-xs text-slate-500 shadow-sm dark:border-slate-800 dark:bg-slate-950 dark:text-slate-400">
            Logo 3
          </div>
          <div class="rounded-xl border border-slate-200 bg-white px-3 py-3 text-center text-xs text-slate-500 shadow-sm dark:border-slate-800 dark:bg-slate-950 dark:text-slate-400">
            Logo 4
          </div>
        </div>

        <p class="mt-3 text-xs text-slate-500 dark:text-slate-400">
          Sponsor logos will be added soon.
        </p>
      </div>

    </div>
  </div>
</footer>