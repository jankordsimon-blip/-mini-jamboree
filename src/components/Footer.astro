---
import { event } from "../config/event";
---

<footer class="mt-16 border-t">
  <div class="mx-auto max-w-6xl px-6 py-10 text-sm text-slate-600">
    <p class="font-medium text-slate-900">{event.name}</p>
    <p class="mt-2">{event.date} · {event.location}</p>
    <p class="mt-4">
      Contact:
      <a class="underline hover:text-slate-900" href={"mailto:" + event.contactEmail}>
        {event.contactEmail}
      </a>
    </p>

    <div class="my-8 h-px w-full bg-slate-200"></div>

    <div class="text-xs text-slate-500">
      <div class="flex items-center justify-between gap-4 flex-wrap">
        <p class="font-medium text-slate-700">Sponsors</p>
        <a class="underline hover:text-slate-700" href="/contact">Become a sponsor</a>
      </div>

      <div class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-4">
        <div class="rounded-lg border bg-white px-3 py-2 text-center">Logo 1</div>
        <div class="rounded-lg border bg-white px-3 py-2 text-center">Logo 2</div>
        <div class="rounded-lg border bg-white px-3 py-2 text-center">Logo 3</div>
        <div class="rounded-lg border bg-white px-3 py-2 text-center">Logo 4</div>
      </div>
    </div>
  </div>
</footer>
