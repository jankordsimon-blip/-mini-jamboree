---
import { event } from "../config/event";

import biozym from "../assets/sponsors/BiozymScience logo.svg";
import carlRoth from "../assets/sponsors/Carl_Roth_Logo.svg";
import microsynth from "../assets/sponsors/microsynth-ag-seeklogo-2.svg";
import snapgene from "../assets/sponsors/Snapgene logo.svg";
import sparkasse from "../assets/sponsors/Sparkasse.svg";

const sponsors = [
  {
    name: "Carl Roth",
    logo: carlRoth,
    url: "https://www.carlroth.com/",
  },
  {
    name: "Microsynth",
    logo: microsynth,
    url: "https://www.microsynth.com/",
  },
  {
    name: "SnapGene",
    logo: snapgene,
    url: "https://www.snapgene.com/",
  },
  {
    name: "Biozym",
    logo: biozym,
    url: "https://www.biozym.com/",
  },
  {
    name: "Sparkasse Münsterland Ost",
    logo: sparkasse,
    url: "https://www.sparkasse-muensterland-ost.de/",
  },
];
---

<footer class="mt-16 border-t border-slate-200 bg-white/70 backdrop-blur dark:border-slate-800 dark:bg-slate-950/40">
  <div class="mx-auto max-w-6xl px-6 py-12 text-sm text-slate-600 dark:text-slate-300">
    
    <div class="flex flex-col gap-10 md:flex-row md:items-start md:justify-between">

      <!-- Event Info -->
      <div>
        <p class="font-semibold text-slate-900 dark:text-white">{event.name}</p>
        <p class="mt-2">{event.date} · {event.location}</p>
        <p class="mt-4">
          Contact:{" "}
          <a class="underline hover:text-slate-900 dark:hover:text-white" href={"mailto:" + event.contactEmail}>
            {event.contactEmail}
          </a>
        </p>
      </div>

      <!-- Sponsors -->
      <div class="w-full md:w-[520px]">
        <div class="flex items-center justify-between">
          <p class="font-semibold text-slate-900 dark:text-white">Sponsors</p>
          <a class="text-xs underline hover:text-slate-900 dark:hover:text-white" href="/contact">
            Become a sponsor
          </a>
        </div>

        <div class="mt-6 grid grid-cols-2 gap-6 sm:grid-cols-3 md:grid-cols-3">
          {sponsors.map((s) => (
            <a
              href={s.url}
              target="_blank"
              rel="noreferrer"
              class="flex items-center justify-center rounded-xl border border-slate-200 bg-white p-4 transition hover:shadow-md dark:border-slate-800 dark:bg-slate-900"
            >
              <img
                src={s.logo.src}
                alt={s.name}
                class="max-h-14 w-auto object-contain grayscale opacity-80 transition hover:grayscale-0 hover:opacity-100"
              />
            </a>
          ))}
        </div>
      </div>

    </div>
  </div>
</footer>