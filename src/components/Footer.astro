---
import { event } from "../config/event";

import biozym from "../assets/sponsors/Biozym-logo.jpg";
import carlRoth from "../assets/sponsors/Carl-Roth-logo.png";
import microsynth from "../assets/sponsors/microsynth-ag-seeklogo-2.svg";
import snapgene from "../assets/sponsors/SnapGene Logo.png";
import sparkasse from "../assets/sponsors/Sparkasse.jpeg";
import biorender from "../assets/sponsors/Blue_Square_Reversed-01_1_.svg";
import kws from "../assets/sponsors/Bild 05.05.26 um 14.48.png";

const sponsors = [
  {
    name: "KWS Saat",
    logo: kws,
  },
  {
    name: "Carl Roth",
    logo: carlRoth,
  },
  {
    name: "Microsynth",
    logo: microsynth,
  },
  {
    name: "SnapGene",
    logo: snapgene,
  },
  {
    name: "Biozym",
    logo: biozym,
  },
  {
    name: "Sparkasse Münsterland Ost",
    logo: sparkasse,
  },
  {
    name: "Biorender",
    logo: biorender,
  },
];
---

<footer class="mt-16 border-t border-slate-200 bg-white/70 backdrop-blur dark:border-slate-800 dark:bg-slate-950/40">
  <div class="mx-auto max-w-6xl px-6 py-12 text-sm text-slate-600 dark:text-slate-300">
    <div class="flex flex-col gap-10 md:flex-row md:items-start md:justify-between">
      <div>
        <p class="font-semibold text-slate-900 dark:text-white">{event.name}</p>
        <p class="mt-2">{event.date} · {event.location}</p>
        <p class="mt-4">
          Contact:{" "}
          <a class="underline hover:text-slate-900 dark:hover:text-white" href={"mailto:" + event.contactEmail}>
            {event.contactEmail}
          </a>
        </p>
      </div>

      <div class="w-full md:w-[560px]">
        <div class="flex items-center justify-between">
          <p class="font-semibold text-slate-900 dark:text-white">Sponsors</p>
          <a class="text-xs underline hover:text-slate-900 dark:hover:text-white" href="/contact">
            Become a sponsor
          </a>
        </div>

        <div class="mt-6 grid grid-cols-2 gap-6 sm:grid-cols-3">
          {sponsors.map((s) => (
            <a
              href={s.url}
              target="_blank"
              rel="noreferrer"
              class="flex min-h-[96px] items-center justify-center rounded-xl border border-slate-200 bg-white p-4 transition hover:shadow-md dark:border-slate-800 dark:bg-slate-900"
            >
              <img
                src={s.logo.src}
                alt={s.name}
                class="max-h-14 w-auto object-contain"
              />
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</footer>