---
import logo from "../public/favicon.png";
import { event } from "../config/event";

const links = [
  { href: "/program", label: "Program" },
  { href: "/venue", label: "Venue" },
  { href: "/faq", label: "FAQ" },
  { href: "/contact", label: "Contact" },
];
---

<header class="border-b border-slate-800 bg-slate-900">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a href="/" class="flex items-center gap-3 text-white">
      <img
        src={logo.src}
        alt="iGEM Münster Junior Jam logo"
        class="h-10 w-auto"
      />
      <span class="font-semibold tracking-tight">{event.name}</span>
    </a>

    <div class="flex items-center gap-4 text-sm">
      {links.map((l) => (
        <a class="text-slate-200 hover:text-white hover:underline" href={l.href}>
          {l.label}
        </a>
      ))}

      <a
        class="ml-1 rounded-xl bg-emerald-500 px-4 py-2 font-semibold text-slate-950 hover:bg-emerald-400"
        href="/register"
      >
        Interested
      </a>
    </div>
  </nav>
</header>