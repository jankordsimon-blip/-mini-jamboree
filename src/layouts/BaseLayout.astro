---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

const { title = "Mini Jamboree" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- SEO -->
    <title>{title} | iGEM Münster Junior Jam 2026</title>
    <meta name="description" content="Join the iGEM Münster Junior Jam 2026 – a 3-day international meetup with talks, workshops, poster sessions and networking for iGEM teams." />
    <link rel="canonical" href="https://igem-muenster-juniorjam.com" />

    <!-- Open Graph (for sharing & SEO) -->
    <meta property="og:title" content="iGEM Münster Junior Jam 2026" />
    <meta property="og:description" content="International iGEM meetup in Münster with talks, workshops and networking." />
    <meta property="og:url" content="https://igem-muenster-juniorjam.com" />
    <meta property="og:type" content="website" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="iGEM Münster Junior Jam 2026" />
    <meta name="twitter:description" content="International iGEM meetup in Münster with talks, workshops and networking." />

    <script type="application/ld+json">
  {JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Event",
    "name": "iGEM Münster Junior Jam 2026",
    "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
    "eventStatus": "https://schema.org/EventScheduled",
    "startDate": "2026-07-10",
    "endDate": "2026-07-12",
    "location": {
      "@type": "Place",
      "name": "University of Münster",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Münster",
        "addressCountry": "DE"
      }
    },
    "image": [
      "https://igem-muenster-juniorjam.com"
    ],
    "description": "The iGEM Münster (iGEM Muenster) Junior Jam 2026 is a 3-day international meetup with talks, workshops, poster sessions and networking for iGEM teams.",
    "organizer": {
      "@type": "Organization",
      "name": "iGEM Münster",
      "url": "https://igem-muenster-juniorjam.com"
    },
    "url": "https://igem-muenster-juniorjam.com"
  })}
</script>

    <!-- Inter Variable (iGEM-like) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400..800&display=swap"
      rel="stylesheet"
    />

    <script>
      (function () {
        const stored = localStorage.getItem("theme");
        const prefersDark = window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches;
        const theme = stored || (prefersDark ? "dark" : "light");
        document.documentElement.classList.toggle("dark", theme === "dark");
      })();
    </script>
  </head>

  <body class="min-h-screen bg-white text-slate-900 dark:bg-slate-950 dark:text-slate-100">
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>