---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Program">
  <section class="mx-auto max-w-4xl px-6 py-16">
    <h1 class="text-4xl font-bold tracking-tight">Program</h1>
    <p class="mt-4 text-slate-600">
      The detailed timetable will be announced soon. The International Junior Jam will include:
    </p>

    <div class="mt-10 grid gap-4 sm:grid-cols-2">
      <div class="rounded-2xl border p-5">
        <h2 class="font-semibold">Team talks</h2>
        <p class="mt-2 text-slate-600">Short presentations by participating iGEM teams.</p>
      </div>
      <div class="rounded-2xl border p-5">
        <h2 class="font-semibold">Poster session</h2>
        <p class="mt-2 text-slate-600">Share your project and receive structured feedback.</p>
      </div>
      <div class="rounded-2xl border p-5">
        <h2 class="font-semibold">Workshops</h2>
        <p class="mt-2 text-slate-600">Hands-on sessions on key iGEM-related topics.</p>
      </div>
      <div class="rounded-2xl border p-5">
        <h2 class="font-semibold">Panel discussions</h2>
        <p class="mt-2 text-slate-600">Interactive discussions with invited guests.</p>
      </div>
      <div class="rounded-2xl border p-5">
        <h2 class="font-semibold">Judging session</h2>
        <p class="mt-2 text-slate-600">A judging/feedback format (details and criteria TBA).</p>
      </div>
      <div class="rounded-2xl border p-5">
        <h2 class="font-semibold">Networking</h2>
        <p class="mt-2 text-slate-600">Meet teams and connect with the community.</p>
      </div>
    </div>
  </section>
</BaseLayout>
