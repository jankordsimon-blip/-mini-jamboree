---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Program">
  <section class="mx-auto max-w-6xl px-6 py-16">
    <h1 class="text-4xl font-extrabold tracking-tight">Program</h1>
    <p class="mt-4 max-w-3xl text-slate-700 dark:text-slate-200">
      The detailed timetable will be published soon. Explore the planned formats below.
    </p>

    <div class="mt-8 flex flex-wrap gap-3">
      <a class="chip" href="#talks">Talks</a>
      <a class="chip" href="#posters">Posters</a>
      <a class="chip" href="#workshops">Workshops</a>
      <a class="chip" href="#panel">Panel</a>
      <a class="chip" href="#judging">Judging</a>
      <a class="chip" href="#networking">Networking</a>
    </div>

    <div class="mt-10 grid gap-4 md:grid-cols-2">
      <div id="talks" class="card card-dark p-6">
        <h2 class="text-xl font-bold">Team talks</h2>
        <p class="mt-2 text-slate-600 dark:text-slate-300">
          Short presentations by participating iGEM teams.
        </p>
      </div>

      <div id="posters" class="card card-dark p-6">
        <h2 class="text-xl font-bold">Poster session</h2>
        <p class="mt-2 text-slate-600 dark:text-slate-300">
          Share your project and receive structured feedback.
        </p>
      </div>

      <div id="workshops" class="card card-dark p-6">
        <h2 class="text-xl font-bold">Workshops</h2>
        <p class="mt-2 text-slate-600 dark:text-slate-300">
          Hands-on sessions on key iGEM-related topics.
        </p>
      </div>

      <div id="panel" class="card card-dark p-6">
        <h2 class="text-xl font-bold">Panel discussions</h2>
        <p class="mt-2 text-slate-600 dark:text-slate-300">
          Interactive discussions with invited guests.
        </p>
      </div>

      <div id="judging" class="card card-dark p-6">
        <h2 class="text-xl font-bold">Judging session</h2>
        <p class="mt-2 text-slate-600 dark:text-slate-300">
          A judging/feedback format (details and criteria TBA).
        </p>
      </div>

      <div id="networking" class="card card-dark p-6">
        <h2 class="text-xl font-bold">Networking</h2>
        <p class="mt-2 text-slate-600 dark:text-slate-300">
          Meet teams and connect with the community.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
