---
import BaseLayout from "../layouts/BaseLayout.astro";
import { event } from "../config/event";

// 👉 wichtig für GitHub Pages
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Contact">
  <section class="mx-auto max-w-6xl px-6 py-16">
    <h1 class="text-4xl font-extrabold tracking-tight">Contact</h1>
    <p class="mt-4 max-w-3xl text-slate-700 dark:text-slate-200">
      Reach out to the organizing team or follow iGEM Münster on social media.
    </p>

    <div class="mt-10 grid gap-4 md:grid-cols-2">
      
      <div class="card card-dark p-6">
        <h2 class="text-xl font-bold">Organizing team</h2>
        <p class="mt-3 text-slate-600 dark:text-slate-300">
          Questions about the event? Contact us via email:
        </p>

        <p class="mt-4">
          <a class="underline hover:text-slate-900 dark:hover:text-white" href={"mailto:" + event.contactEmail}>
            {event.contactEmail}
          </a>
        </p>

        <div class="mt-8">
          <h3 class="text-sm font-semibold text-slate-900 dark:text-white">Socials</h3>
          <ul class="mt-3 space-y-2 text-sm text-slate-700 dark:text-slate-200">
            <li>
              Website:{" "}
              {event.socials.website ? (
                <a class="underline hover:text-slate-900 dark:hover:text-white" href={event.socials.website} target="_blank" rel="noreferrer">
                  iGEM Münster Website
                </a>
              ) : (
                <span class="text-slate-400">TBA</span>
              )}
            </li>
            <li>
              Instagram:{" "}
              {event.socials.instagram ? (
                <a class="underline hover:text-slate-900 dark:hover:text-white" href={event.socials.instagram} target="_blank" rel="noreferrer">
                  @igem_muenster
                </a>
              ) : (
                <span class="text-slate-400">TBA</span>
              )}
            </li>
            <li>
              GitHub:{" "}
              {event.socials.github ? (
                <a class="underline hover:text-slate-900 dark:hover:text-white" href={event.socials.github} target="_blank" rel="noreferrer">
                  iGEM Münster on GitHub
                </a>
              ) : (
                <span class="text-slate-400">TBA</span>
              )}
            </li>
          </ul>
        </div>
      </div>

      <div class="card card-dark p-6">
        <h2 class="text-xl font-bold">Expression of interest</h2>
        <p class="mt-3 text-slate-600 dark:text-slate-300">
          Want to participate with your iGEM team? Leave your details and we will notify you when Indico registration opens.
        </p>

        <!-- ✅ FIXED BUTTONS -->
        <div class="mt-6 flex flex-wrap gap-3">
          <a class="btn btn-primary" href={`${base}/register`}>Register interest</a>
          <a class="btn btn-secondary" href={`${base}/faq`}>Read FAQ</a>
        </div>

        <p class="mt-4 text-sm text-slate-500 dark:text-slate-400">
          Participation fee is TBA.
        </p>
      </div>

    </div>
  </section>
</BaseLayout>