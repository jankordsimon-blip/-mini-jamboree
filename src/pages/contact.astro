---
import BaseLayout from "../layouts/BaseLayout.astro";
import { event } from "../config/event";
---

<BaseLayout title="Contact">
  <section class="mx-auto max-w-4xl px-6 py-16">
    <h1 class="text-4xl font-bold tracking-tight">Contact</h1>

    <div class="mt-8 grid gap-6 md:grid-cols-2">
      <div class="rounded-2xl border p-6">
        <h2 class="text-xl font-semibold">Organizing team</h2>
        <p class="mt-3 text-slate-600">
          Questions about the event? Reach out via email:
        </p>
        <p class="mt-3">
          <a class="underline hover:text-slate-900" href={"mailto:" + event.contactEmail}>
            {event.contactEmail}
          </a>
        </p>

        <div class="mt-6">
          <h3 class="text-sm font-semibold text-slate-700">Socials</h3>
          <ul class="mt-3 space-y-2 text-sm text-slate-600">
            <li>
              Website:{" "}
              {event.socials.website ? (
                <a class="underline hover:text-slate-900" href={event.socials.website} target="_blank" rel="noreferrer">
                  iGEM Münster Website
                </a>
              ) : (
                <span class="text-slate-400">TBA</span>
              )}
            </li>
            <li>
              Instagram:{" "}
              {event.socials.instagram ? (
                <a class="underline hover:text-slate-900" href={event.socials.instagram} target="_blank" rel="noreferrer">
                  @igem_muenster
                </a>
              ) : (
                <span class="text-slate-400">TBA</span>
              )}
            </li>
            <li>
              GitHub:{" "}
              {event.socials.github ? (
                <a class="underline hover:text-slate-900" href={event.socials.github} target="_blank" rel="noreferrer">
                  iGEM Münster on GitHub
                </a>
              ) : (
                <span class="text-slate-400">TBA</span>
              )}
            </li>
          </ul>
        </div>
      </div>

      <div class="rounded-2xl border p-6">
        <h2 class="text-xl font-semibold">Expression of interest</h2>
        <p class="mt-3 text-slate-600">
          Want to participate with your iGEM team? Leave your details and we will notify you when Indico registration opens.
        </p>

        <a
          class="mt-6 inline-block rounded-lg bg-black px-5 py-3 text-white hover:bg-slate-800"
          href="/register"
        >
          I’m interested
        </a>

        <p class="mt-4 text-sm text-slate-500">
          Participation fee is TBA.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
