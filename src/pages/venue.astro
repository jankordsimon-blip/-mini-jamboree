---
import BaseLayout from "../layouts/BaseLayout.astro";
import { event } from "../config/event";
---

<BaseLayout title="Venue & Travel">
  <section class="mx-auto max-w-4xl px-6 py-16">
    <h1 class="text-4xl font-bold tracking-tight">Venue & Travel</h1>
    <p class="mt-4 text-slate-600">
      The event takes place in Münster at the University of Münster. Exact rooms/buildings will be published soon.
    </p>

    <div class="mt-10 space-y-6">
      <div class="rounded-2xl border p-6">
        <h2 class="text-xl font-semibold">Address (preliminary)</h2>
        <p class="mt-3 text-slate-600">
          {event.location}
        </p>
        <p class="mt-3 text-sm text-slate-500">
          We will share the final venue address and building information closer to the event.
        </p>
      </div>

      <div class="rounded-2xl border p-6">
        <h2 class="text-xl font-semibold">Getting to Münster</h2>
        <ul class="mt-3 list-disc space-y-2 pl-5 text-slate-600">
          <li><span class="font-medium">Train:</span> Münster (Westf) Hbf</li>
          <li><span class="font-medium">Airports:</span> Düsseldorf (DUS), Dortmund (DTM), Münster/Osnabrück (FMO)</li>
          <li><span class="font-medium">Local transport:</span> buses, walking, and bike-friendly routes</li>
        </ul>
      </div>

      <div class="rounded-2xl border p-6">
        <h2 class="text-xl font-semibold">Accommodation</h2>
        <p class="mt-3 text-slate-600">
          A list of recommended hotels/hostels and suggested booking window will be published soon.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
