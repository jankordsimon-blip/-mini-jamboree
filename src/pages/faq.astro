---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="FAQ">
  <section class="mx-auto max-w-4xl px-6 py-16">
    <h1 class="text-4xl font-bold tracking-tight">FAQ</h1>

    <div class="mt-10 space-y-8">
      <div>
        <h2 class="text-lg font-semibold">Who can attend?</h2>
        <p class="mt-2 text-slate-600">
          This event is intended for iGEM teams.
        </p>
      </div>

      <div>
        <h2 class="text-lg font-semibold">How do I register?</h2>
        <p class="mt-2 text-slate-600">
          For now, please submit an expression of interest via our registration form.
          Official registration will be handled via Indico (link will be added later).
        </p>
      </div>

      <div>
        <h2 class="text-lg font-semibold">Is there a participation fee?</h2>
        <p class="mt-2 text-slate-600">
          Yes, there will be a participation fee. The amount is TBA and will be announced with the Indico registration.
        </p>
      </div>

      <div>
        <h2 class="text-lg font-semibold">Can we give a talk or present a poster?</h2>
        <p class="mt-2 text-slate-600">
          Yes. Information about formats, submission, and deadlines will be announced soon.
        </p>
      </div>

      <div>
        <h2 class="text-lg font-semibold">Who do we contact for questions?</h2>
        <p class="mt-2 text-slate-600">
          Please use the contact page to reach the organizing team.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
