---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="FAQ">
  <section class="mx-auto max-w-4xl px-6 py-16">
    <h1 class="text-4xl font-bold tracking-tight">FAQ</h1>
    <div class="mt-8 space-y-6">
      <div>
        <h2 class="font-semibold">Who can attend?</h2>
        <p class="mt-2 text-slate-600">iGEM teams, supervisors, and invited guests.</p>
      </div>
      <div>
        <h2 class="font-semibold">How do I register?</h2>
        <p class="mt-2 text-slate-600">Registration is handled via Indico.</p>
      </div>
    </div>
  </section>
</BaseLayout>
