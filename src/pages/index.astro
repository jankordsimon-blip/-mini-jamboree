---
import BaseLayout from "../layouts/BaseLayout.astro";
import { event } from "../config/event";
import heroImage from "../assets/burgen-schloesser-parks-muenster-universitaet-muenster-c-dagmar-schwelle.jpg";
---

<BaseLayout title={event.name}>
  <main>
    <section id="hero" class="relative overflow-hidden min-h-screen">
      <img
        src={heroImage.src}
        alt=""
        class="absolute inset-0 h-full w-full object-cover"
      />

      <div class="absolute inset-0 bg-gradient-to-b from-slate-950/55 via-slate-950/30 to-white/5"></div>
      <div class="absolute inset-0 bg-emerald-500/10 mix-blend-overlay"></div>

      <div class="relative mx-auto max-w-6xl px-6 py-20 md:py-28">
        <div class="max-w-3xl">
          <div class="flex flex-wrap gap-3">
            <span class="chip chip-active">SAVE THE DATE</span>
            <span class="chip bg-white/80 backdrop-blur">{event.date}</span>
            <span class="chip bg-white/80 backdrop-blur">Münster</span>
          </div>

          <h1 class="mt-6 text-5xl font-extrabold tracking-tight text-white md:text-6xl">
            {event.name}
          </h1>

          <p class="mt-6 text-lg text-white/90">
            A 3-day meetup for iGEM teams with talks, poster sessions, networking,
            judging sessions, workshops, and panel discussions.
          </p>

          <div class="mt-8 flex flex-wrap gap-3">
            <a class="btn btn-primary" href="/register">Interested</a>
            <a class="btn btn-secondary bg-white/85 backdrop-blur" href="/program">Program</a>
            <a class="btn btn-secondary bg-white/85 backdrop-blur" href="/venue">Venue & travel</a>
          </div>

          <p class="mt-5 text-sm text-white/80">
            Participation fee and official registration (Indico) will be announced soon.
          </p>

          <a
            href="#content"
            class="relative mt-16 inline-flex items-center gap-2 text-sm font-semibold text-white/90 hover:text-white"
          >
            <span>Scroll</span>
            <span aria-hidden="true">↓</span>
          </a>
        </div>
      </div>
    </section>

    <section id="content" class="mx-auto max-w-6xl px-6 py-16">
      <div class="grid gap-10 md:grid-cols-2 md:items-start">
        <div class="grid gap-3 sm:grid-cols-3">
          <div class="card p-4">
            <p class="text-xs font-semibold text-slate-500">Date</p>
            <p class="mt-1 font-semibold text-slate-900">{event.date}</p>
          </div>

          <div class="card p-4">
            <p class="text-xs font-semibold text-slate-500">Location</p>
            <p class="mt-1 font-semibold text-slate-900">University of Münster</p>
            <p class="mt-1 text-sm text-slate-600">Münster, Germany</p>
          </div>

          <div class="card p-4">
            <p class="text-xs font-semibold text-slate-500">Fee</p>
            <p class="mt-1 font-semibold text-slate-900">TBA</p>
            <p class="mt-1 text-sm text-slate-600">Announced with Indico</p>
          </div>
        </div>

        <div class="card p-6">
          <h2 class="text-lg font-semibold">What To Expect</h2>
          <ul class="mt-4 space-y-2 text-slate-700">
            <li><span class="font-medium">Talks</span> by participating teams</li>
            <li><span class="font-medium">Poster session</span> & feedback</li>
            <li><span class="font-medium">Workshops</span> & skill building</li>
            <li><span class="font-medium">Panel discussions</span> with guests</li>
            <li><span class="font-medium">Judging session</span> (details TBA)</li>
            <li><span class="font-medium">Networking</span> with the community</li>
          </ul>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>