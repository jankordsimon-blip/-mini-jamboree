---
import BaseLayout from "../layouts/BaseLayout.astro";
import { event } from "../config/event";
import heroImage from "../assets/burgen-schloesser-parks-muenster-universitaet-muenster-c-dagmar-schwelle.jpg";
import NewsFeed from "../components/NewsFeed";
import newsImage from "../assets/news/Schmid-Vortrag.jpg";

const updates = [
	{
    date: "March 2026",
    title: "Opening Talk by Prof. Dr. Ing. Jochen Schmid",
    text: "We are excited to announce our opening talk will be held by Jochen Schmid a three time iGEMer, and counting. 
	Professor Schmid's sepciality is in metabolic engeneering and microbial polysaccharides, with profound expertise in industry and circular economy.",
    image: newsImage.src,
  },
  {
    date: "March 2026",
    title: "Interest form is now open",
    text: "You can now let us know if your team is interested in joining the International Junior Jam 2026 in Münster. This is not the official registration yet — teams on the interest list will be notified as soon as Indico registration opens.",
    image: heroImage.src,
  }
];
---

<BaseLayout title={event.name}>
  <main>
    <section id="hero" class="relative overflow-hidden min-h-screen">
      <img
        src={heroImage.src}
        alt=""
        class="absolute inset-0 h-full w-full object-cover"
      />

      <div class="absolute inset-0 bg-gradient-to-b from-slate-950/55 via-slate-950/30 to-white/5"></div>
      <div class="absolute inset-0 bg-emerald-500/10 mix-blend-overlay"></div>

      <div class="relative mx-auto max-w-6xl px-6 py-20 md:py-28">
        <div class="max-w-3xl">
          <div class="flex flex-wrap gap-3">
            <span class="chip chip-active">SAVE THE DATE</span>
            <span class="chip bg-white/80 backdrop-blur">{event.date}</span>
            <span class="chip bg-white/80 backdrop-blur">Münster</span>
          </div>

          <h1 class="mt-6 text-5xl font-extrabold tracking-tight text-white md:text-6xl">
            {event.name}
          </h1>

          <p class="mt-6 text-lg text-white/90">
            A 3-day meetup for iGEM teams with talks, poster sessions, networking,
            judging sessions, workshops, and panel discussions.
          </p>

          <div class="mt-8 flex flex-wrap gap-3">
            <a class="btn btn-primary" href="/register">Interested</a>
            <a class="btn btn-secondary bg-white/85 backdrop-blur" href="/program">Program</a>
            <a class="btn btn-secondary bg-white/85 backdrop-blur" href="/venue">Venue & travel</a>
          </div>

          <p class="mt-5 text-sm text-white/80">
            Participation fee and official registration (Indico) will be announced soon.
          </p>

          <a
            href="#updates"
            class="relative mt-16 inline-flex items-center gap-2 text-sm font-semibold text-white/90 hover:text-white"
          >
            <span>Scroll</span>
            <span aria-hidden="true">↓</span>
          </a>
        </div>
      </div>
    </section>

    <div id="updates">
      <NewsFeed client:load items={updates} />
    </div>
  </main>
</BaseLayout>