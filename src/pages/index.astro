---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Mini Jamboree">
  <main class="mx-auto max-w-4xl px-6 py-16">
    <h1 class="text-5xl font-bold tracking-tight">
      Mini Jamboree
    </h1>

    <p class="mt-4 text-lg text-slate-600">
      If this text looks nicely styled and the button is black, Tailwind works.
    </p>

    <a
      href="#"
      class="mt-8 inline-block rounded-lg bg-black px-5 py-3 text-white hover:bg-slate-800"
    >
      Register (Indico)
    </a>
  </main>
</BaseLayout>
